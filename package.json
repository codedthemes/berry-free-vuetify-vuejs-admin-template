    "@vue/eslint-config-prettier": "10.2.0",
    "@vue/tsconfig": "0.9.0",
    "eslint": "10.0.2",
    "eslint-plugin-vue": "10.8.0",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "sass": "1.97.3",
    "sass-loader": "16.0.7",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vite": "7.3.1",
    "vue-tsc": "3.2.5"
