    "axios": "1.13.6",
    "axios-mock-adapter": "2.1.0",
    "chance": "1.1.13",
    "date-fns": "4.1.0",
    "lodash": "4.17.23",
    "pinia": "3.0.4",
    "vee-validate": "4.15.1",
    "vite-plugin-vuetify": "2.1.3",
    "vue": "3.5.29",
    "vue-eslint-parser": "10.4.0",
    "vue-router": "4.6.3",
    "vue-tabler-icons": "2.21.0",
    "vue3-apexcharts": "1.10.0",
    "vue3-perfect-scrollbar": "2.0.0",
    "vuetify": "4.0.0"
