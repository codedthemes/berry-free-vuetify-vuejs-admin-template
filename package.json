{
  "name": "berry-free-vuetify-vuejs-admin-template",
  "version": "2.0.0",
  "private": true,
  "author": "CodedThemes",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
